---
import type { Lang, Repo } from '../data/types';
import Card from './Card.astro';

interface Props {
  lang: Lang;
  t: {
    reposPageTitle: string;
    reposPageDesc: string;
    visitRepo: string;
    hintText: string;
    backToHome: string;
  };
  repos: Repo[];
  getPath: (path: string) => string;
}

const { lang, t, repos, getPath } = Astro.props;
---

<section class="subpage-section">
  <div class="subpage-header">
    <h1 class="welcome-text"><span class="gradient-text">{t.reposPageTitle}</span></h1>
    <p class="intro-paragraph">{t.reposPageDesc}</p>
  </div>
  
  <div class="subpage-grid">
    {repos.map(repo => (
      <Card
        type="repo"
        url={repo.url}
        image={repo.image}
        title={repo.title}
        tags={repo.tags}
        description={repo.descriptions[lang]}
        badgeLabel={t.visitRepo}
        hintText={t.hintText}
      />
    ))}
  </div>

  <div class="back-link-container">
    <a href={getPath('')} class="back-to-home-link">{t.backToHome}</a>
  </div>
</section>
