---
import type { Lang, TimelineItem } from '../data/types';
import type { Repo, Video } from '../data/types';
import Hero from './Hero.astro';
import Card from './Card.astro';
import Timeline from './Timeline.astro';
import GithubIcon from '../content/github.svg';
import YoutubeIcon from '../content/youtube.svg';
import ArrowIcon from '../content/arrow.svg';

interface Props {
  lang: Lang;
  t: {
    hello: string;
    introText: string;
    reposTitle: string;
    videosTitle: string;
    visitRepo: string;
    watchVideo: string;
    hintText: string;
    seeMore: string;
    timelineTitle: string;
    timeline: TimelineItem[];
    futureText: string;
  };
  repos: Repo[];
  videos: Video[];
  getPath: (path: string) => string;
}

const { lang, t, repos, videos, getPath } = Astro.props;
---

<Hero hello={t.hello} introText={t.introText} />

<section class="grid-section">
  <div class="main-grid">
    
    <div class="column">
      <div class="column-header-container">
        <GithubIcon class="col-icon repo-col-icon" />
        <h2 class="column-title">{t.reposTitle}</h2>
      </div>
      
      <div class="cards-list">
        {repos.slice(0,2).map(repo => (
          <Card
            type="repo"
            url={repo.url}
            image={repo.image}
            title={repo.title}
            tags={repo.tags}
            description={repo.descriptions[lang]}
            badgeLabel={t.visitRepo}
            hintText={t.hintText}
          />
        ))}
      </div>
      
      <div class="see-more-container">
        <a href={getPath('repositories')} class="see-more-btn repo-see-more">
          <span>{t.seeMore}</span>
          <ArrowIcon class="arrow-icon-btn" stroke-width="2.5" />
        </a>
      </div>
    </div>

    <div class="column">
      <div class="column-header-container">
        <YoutubeIcon class="col-icon video-col-icon" />
        <h2 class="column-title">{t.videosTitle}</h2>
      </div>

      <div class="cards-list">
        {videos.slice(0,2).map(video => (
          <Card
            type="video"
            url={video.url}
            image={video.image}
            title={video.title[lang]}
            tags={video.tags}
            description={video.descriptions[lang]}
            badgeLabel={t.watchVideo}
            hintText={t.hintText}
          />
        ))}
      </div>
      
      <div class="see-more-container">
        <a href={getPath('videos')} class="see-more-btn video-see-more">
          <span>{t.seeMore}</span>
          <ArrowIcon class="arrow-icon-btn" stroke-width="2.5" />
        </a>
      </div>
    </div>

  </div>
</section>

<Timeline
  timelineTitle={t.timelineTitle}
  timeline={t.timeline}
  futureText={t.futureText}
/>

<style>
  .grid-section {
    margin-bottom: 5rem;
  }

  .main-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: stretch;
  }

  .column {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .column-header-container {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 0.75rem;
  }

  .col-icon {
    width: 24px;
    height: 24px;
  }

  .repo-col-icon {
    color: var(--color-repo);
    filter: drop-shadow(0 0 6px var(--color-repo-glow));
  }

  .video-col-icon {
    color: var(--color-video);
    filter: drop-shadow(0 0 6px var(--color-video-glow));
  }

  .column-title {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .cards-list {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 1.75rem;
    flex-grow: 1;
  }

  .see-more-container {
    margin-top: 1.75rem;
    display: flex;
    justify-content: center;
  }

  .see-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.5rem;
    border-radius: 9999px;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .arrow-icon-btn {
    width: 14px;
    height: 14px;
    transition: transform 0.3s ease;
  }

  .see-more-btn:hover {
    color: #fff;
    transform: translateY(-2px);
  }

  .see-more-btn:hover .arrow-icon-btn {
    transform: translateX(4px);
  }

  .repo-see-more:hover {
    border-color: var(--color-repo);
    background: rgba(59, 130, 246, 0.05);
    box-shadow: 0 4px 20px rgba(59, 130, 246, 0.15);
  }

  .video-see-more:hover {
    border-color: var(--color-video);
    background: rgba(239, 68, 68, 0.05);
    box-shadow: 0 4px 20px rgba(239, 68, 68, 0.15);
  }

  @media (max-width: 900px) {
    .main-grid {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }
    .cards-list {
      grid-template-rows: auto auto;
    }
  }
</style>
