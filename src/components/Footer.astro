---
interface Props {
  socialsTitleText: string;
  discordTooltipText: string;
  linkedinFutureText: string;
  emailTooltipText: string;
  emailSubjectText: string;
}

const { socialsTitleText, discordTooltipText, linkedinFutureText, emailTooltipText, emailSubjectText } = Astro.props;
---

<footer class="socials-section">
  <h2 class="socials-title">{socialsTitleText}</h2>
  
  <div class="socials-grid">
    <a href="https://github.com/adriabama06" class="social-btn github-btn" target="_blank" rel="noopener noreferrer">
      <svg class="social-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
      <span class="social-label">GitHub</span>
    </a>

    <a href="https://www.youtube.com/@adriabama06" class="social-btn youtube-btn" target="_blank" rel="noopener noreferrer">
      <svg class="social-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25a29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
      <span class="social-label">YouTube</span>
    </a>

    <button id="discord-copy-btn" class="social-btn discord-btn" data-tooltip={discordTooltipText} aria-label="Copy Discord username">
      <svg class="social-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 127.14 96.36" fill="currentColor">
        <path d="M107.7,8.07A105.15,105.15,0,0,0,77.26,0a77.19,77.19,0,0,0-3.3,6.83A96.67,96.67,0,0,0,53.22,6.83,77.19,77.19,0,0,0,49.88,0,105.15,105.15,0,0,0,19.44,8.07C3.66,31.58-1.86,54.65,1,77.53A105.73,105.73,0,0,0,32,96.36a74.37,74.37,0,0,0,6.72-11,68.6,68.6,0,0,1-10.64-5.12c.91-.67,1.81-1.37,2.67-2.1a75.22,75.22,0,0,0,72.71,0c.87.73,1.76,1.43,2.67,2.1a68.86,68.86,0,0,1-10.64,5.12,74.74,74.74,0,0,0,6.72,11,105.73,105.73,0,0,0,31-18.83C129.24,48.72,123.34,25.94,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53S36.18,40.36,42.45,40.36,53.9,46,53.77,53,48.72,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.24,60,73.24,53S78.41,40.36,84.69,40.36,96.14,46,96,53,91,65.69,84.69,65.69Z"/>
      </svg>
      <span class="social-label" id="discord-label">Discord</span>
    </button>

    <div class="social-btn linkedin-btn disabled-btn" title={linkedinFutureText}>
      <svg class="social-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
      <span class="social-label">{linkedinFutureText}</span>
    </div>

    <a href={`mailto:adriabama06@gmail.com?subject=${encodeURIComponent(emailSubjectText)}`} class="social-btn email-btn" title={emailTooltipText}>
      <svg class="social-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
      <span class="social-label">Email</span>
    </a>
  </div>
</footer>

<script>
  const copyBtn = document.getElementById('discord-copy-btn');

  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText('adriabama06');
        copyBtn.classList.add('copied');
        
        setTimeout(() => {
          copyBtn.classList.remove('copied');
        }, 1000);
      } catch (err) {
        console.error('Could not copy text: ', err);
      }
    });
  }
</script>

<style>
  .socials-section {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .socials-title {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 2rem;
    letter-spacing: -0.01em;
  }

  .socials-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    width: 100%;
    max-width: 800px;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.25rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    outline: none;
    -webkit-tap-highlight-color: transparent;
  }

  .social-svg {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .social-btn:hover {
    color: var(--text-main);
    transform: translateY(-3px);
  }

  .social-btn:hover .social-svg {
    transform: scale(1.15);
  }

  .social-btn[data-tooltip]::before {
    content: attr(data-tooltip);
    position: absolute;
    bottom: 125%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    background: #0f172a;
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    font-size: 0.75rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: all 0.2s ease;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
    z-index: 100;
  }

  .social-btn[data-tooltip]:hover::before {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .github-btn:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: #f3f4f6;
    box-shadow: 0 10px 20px rgba(255, 255, 255, 0.05);
  }

  .youtube-btn:hover {
    background: rgba(239, 68, 68, 0.05);
    border-color: #ef4444;
    box-shadow: 0 10px 20px rgba(239, 68, 68, 0.08);
  }

  .discord-btn {
    border: 1px solid var(--border-color);
  }

  .discord-btn:hover {
    background: rgba(88, 101, 242, 0.05);
    border-color: #5865f2;
    box-shadow: 0 10px 20px rgba(88, 101, 242, 0.08);
  }

  .discord-btn.copied {
    border-color: #10b981;
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
  }

  .email-btn:hover {
    background: rgba(14, 165, 233, 0.05);
    border-color: #0ea5e9;
    box-shadow: 0 10px 20px rgba(14, 165, 233, 0.08);
  }

  .disabled-btn {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: auto;
  }

  .disabled-btn:hover {
    transform: none;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.02);
    border-color: var(--border-color);
  }

  @media (max-width: 600px) {
    .socials-grid {
      flex-direction: column;
      align-items: stretch;
    }

    .social-btn {
      justify-content: center;
    }

    .social-btn[data-tooltip]::before {
      display: none;
    }
  }
</style>
