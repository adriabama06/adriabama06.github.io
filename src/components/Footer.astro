---
import GithubIcon from '../content/github.svg';
import YoutubeIcon from '../content/youtube.svg';
import DiscordIcon from '../content/discord.svg';
import LinkedinIcon from '../content/linkedin.svg';
import EmailIcon from '../content/email.svg';

interface Props {
  socialsTitleText: string;
  discordTooltipText: string;
  linkedinFutureText: string;
  emailTooltipText: string;
  emailSubjectText: string;
}

const { socialsTitleText, discordTooltipText, linkedinFutureText, emailTooltipText, emailSubjectText } = Astro.props;
---

<footer class="socials-section">
  <h2 class="socials-title">{socialsTitleText}</h2>
  
  <div class="socials-grid">
    <a href="https://github.com/adriabama06" class="social-btn github-btn" target="_blank" rel="noopener noreferrer">
      <GithubIcon class="social-svg" />
      <span class="social-label">GitHub</span>
    </a>

    <a href="https://www.youtube.com/@adriabama06" class="social-btn youtube-btn" target="_blank" rel="noopener noreferrer">
      <YoutubeIcon class="social-svg" />
      <span class="social-label">YouTube</span>
    </a>

    <button id="discord-copy-btn" class="social-btn discord-btn" data-tooltip={discordTooltipText} aria-label="Copy Discord username">
      <DiscordIcon class="social-svg" />
      <span class="social-label" id="discord-label">Discord</span>
    </button>

    <div class="social-btn linkedin-btn disabled-btn" title={linkedinFutureText}>
      <LinkedinIcon class="social-svg" />
      <span class="social-label">{linkedinFutureText}</span>
    </div>

    <a href={`mailto:adriabama06@gmail.com?subject=${encodeURIComponent(emailSubjectText)}`} class="social-btn email-btn" title={emailTooltipText}>
      <EmailIcon class="social-svg" />
      <span class="social-label">Email</span>
    </a>
  </div>
</footer>

<script>
  const copyBtn = document.getElementById('discord-copy-btn');

  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText('adriabama06');
        copyBtn.classList.add('copied');
        
        setTimeout(() => {
          copyBtn.classList.remove('copied');
        }, 1000);
      } catch (err) {
        console.error('Could not copy text: ', err);
      }
    });
  }
</script>

<style>
  .socials-section {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .socials-title {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 2rem;
    letter-spacing: -0.01em;
  }

  .socials-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    width: 100%;
    max-width: 800px;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.25rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    outline: none;
    -webkit-tap-highlight-color: transparent;
  }

  .social-svg {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .social-btn:hover {
    color: var(--text-main);
    transform: translateY(-3px);
  }

  .social-btn:hover .social-svg {
    transform: scale(1.15);
  }

  .social-btn[data-tooltip]::before {
    content: attr(data-tooltip);
    position: absolute;
    bottom: 125%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    background: #0f172a;
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    font-size: 0.75rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: all 0.2s ease;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
    z-index: 100;
  }

  .social-btn[data-tooltip]:hover::before {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .github-btn:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: #f3f4f6;
    box-shadow: 0 10px 20px rgba(255, 255, 255, 0.05);
  }

  .youtube-btn:hover {
    background: rgba(239, 68, 68, 0.05);
    border-color: #ef4444;
    box-shadow: 0 10px 20px rgba(239, 68, 68, 0.08);
  }

  .discord-btn {
    border: 1px solid var(--border-color);
  }

  .discord-btn:hover {
    background: rgba(88, 101, 242, 0.05);
    border-color: #5865f2;
    box-shadow: 0 10px 20px rgba(88, 101, 242, 0.08);
  }

  .discord-btn.copied {
    border-color: #10b981;
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
  }

  .email-btn:hover {
    background: rgba(14, 165, 233, 0.05);
    border-color: #0ea5e9;
    box-shadow: 0 10px 20px rgba(14, 165, 233, 0.08);
  }

  .disabled-btn {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: auto;
  }

  .disabled-btn:hover {
    transform: none;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.02);
    border-color: var(--border-color);
  }

  .disabled-btn:hover .social-svg {
    transform: none;
  }

  @media (max-width: 600px) {
    .socials-grid {
      flex-direction: column;
      align-items: stretch;
    }

    .social-btn {
      justify-content: center;
    }

    .social-btn[data-tooltip]::before {
      display: none;
    }
  }
</style>
