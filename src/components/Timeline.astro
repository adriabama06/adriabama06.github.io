---
import type { TimelineItem } from '../data/types';
import LinkIcon from '../content/link.svg';

interface Props {
  timelineTitle: string;
  timeline: TimelineItem[];
  futureText: string;
}

const { timelineTitle, timeline, futureText } = Astro.props;
---

<section class="timeline-section">
  <h2 class="timeline-section-title">{timelineTitle}</h2>
  
  <div class="timeline-wrapper">
    {timeline.map((item, index) => {
      const prevItem = timeline[index - 1];
      const nextItem = timeline[index + 1];
      
      const prevColor = prevItem ? prevItem.color : 'transparent';
      const nextColor = nextItem ? nextItem.color : 'transparent';
      
      // Calculamos el color exacto donde se unen la tarjeta actual y la siguiente/anterior
      // Esto hace que el degradado sea visualmente ininterrumpido a lo largo de toda la línea
      const mixTop = index > 0 
        ? `color-mix(in srgb, ${prevColor} 50%, ${item.color} 50%)` 
        : item.color;
        
      const mixBottom = nextItem 
        ? `color-mix(in srgb, ${item.color} 50%, ${nextColor} 50%)`
        : `color-mix(in srgb, ${item.color} 50%, transparent 50%)`;

      return (
        <div class="timeline-item">
          <div class="timeline-track">
            {/* Línea superior: desde el borde de arriba de la tarjeta hasta el centro del punto */}
            {index > 0 && (
              <div 
                class="timeline-line-top" 
                style={`background: linear-gradient(to bottom, ${mixTop}, ${item.color});`}
              />
            )}
            
            {/* Punto: Centrado verticalmente de manera perfecta respecto a la tarjeta */}
            <div 
              class="timeline-dot" 
              style={`background-color: ${item.color}; border-color: ${item.color}; box-shadow: 0 0 12px ${item.color}66;`}
            />
            
            {/* Línea inferior: Atraviesa el padding (gap) para juntarse exactamente con la siguiente tarjeta */}
            <div 
              class="timeline-line-bottom" 
              style={`background: linear-gradient(to bottom, ${item.color}, ${mixBottom});`}
            />
          </div>
          
          <div 
            class={`timeline-card ${index === timeline.length - 1 ? 'highlighted-timeline-card' : ''}`}
            style={`--item-color: ${item.color};`}
          >
            {index === timeline.length - 1 && (
              <div class="live-pulse" style={`--pulse-color: ${item.color};`} />
            )}
            <h3 class="timeline-card-title">{item.title}</h3>
            <p class="timeline-card-desc">{item.content}</p>
            {item.links && item.links.length > 0 && (
              <div class="timeline-card-links">
                {item.links.map((link) => (
                  <a 
                    href={link.url} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="timeline-card-link"
                    style={`--link-color: ${item.color};`}
                  >
                    <LinkIcon class="link-icon" width="12" height="12" />
                    {link.text}
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      );
    })}

    {/* Standalone Future Item */}
    <div class="timeline-item future-item">
      <div class="timeline-track">
        {/* La línea del futuro completa el degradado final mezclándose perfectamente con transparente */}
        <div 
          class="timeline-line-top" 
          style={`background: linear-gradient(to bottom, color-mix(in srgb, ${timeline[timeline.length - 1].color} 50%, transparent 50%), transparent);`}
        />
        <div class="timeline-dot future-dot" />
      </div>
      <div class="timeline-future-text">
        {futureText}
      </div>
    </div>
  </div>
</section>

<style>
  .timeline-section {
    margin-bottom: 6rem;
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .timeline-section-title {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 3.5rem;
    letter-spacing: -0.02em;
    position: relative;
  }

  .timeline-section-title::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 25%;
    width: 50%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-theme-a), transparent);
  }

  .timeline-wrapper {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 640px;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .timeline-item {
    display: flex;
    gap: 1.75rem;
    width: 100%;
    position: relative;
    --item-padding: 2.5rem;
  }

  .timeline-item:not(:last-child) {
    padding-bottom: var(--item-padding);
  }

  .future-item {
    --item-padding: 0px;
    align-items: center;
  }

  .timeline-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 18px;
    flex-shrink: 0;
    position: relative;
    align-self: stretch; /* Esto hace que el track mida exactamente lo mismo que la tarjeta */
  }

  .timeline-dot {
    position: absolute;
    top: 50%; /* Al estar alineado al stretch de la tarjeta, el 50% es su centro exacto */
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 3px solid var(--border-color);
    z-index: 10;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .timeline-item:has(.timeline-card:hover) .timeline-dot:not(.future-dot) {
    transform: translateY(-50%) scale(1.25);
  }

  .timeline-line-top {
    position: absolute;
    top: 0;
    height: 50%; /* Llega justo hasta el centro del punto */
    width: 3px;
    z-index: 1;
  }

  .timeline-line-bottom {
    position: absolute;
    top: 50%;
    height: calc(50% + var(--item-padding)); /* Penetra el padding inferior para conectar milimétricamente con el siguiente top */
    width: 3px;
    z-index: 1;
  }

  .timeline-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 14px;
    padding: 1.25rem 1.75rem;
    flex-grow: 1;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .timeline-card:hover {
    transform: translateX(6px);
    border-color: var(--item-color);
  }

  .timeline-card-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .timeline-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    padding: 0.25rem 0.6rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .timeline-card-link:hover {
    color: #fff;
    background: color-mix(in srgb, var(--link-color) 15%, transparent);
    border-color: var(--link-color);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--link-color) 20%, transparent);
  }

  .link-icon {
    opacity: 0.7;
    transition: opacity 0.2s ease;
    min-width: 12px;
  }

  .timeline-card-link:hover .link-icon {
    opacity: 1;
  }

  .highlighted-timeline-card {
    border-color: rgba(14, 165, 233, 0.3);
    position: relative;
    overflow: hidden;
  }

  .highlighted-timeline-card:hover {
    box-shadow: 0 8px 25px rgba(14, 165, 233, 0.15);
  }

  .live-pulse {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 8px;
    height: 8px;
    background-color: var(--pulse-color);
    border-radius: 50%;
  }

  .live-pulse::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--pulse-color);
    border-radius: 50%;
    animation: pulseGlow 1.8s infinite ease-in-out;
  }

  @keyframes pulseGlow {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(3.5); opacity: 0; }
  }

  .timeline-card-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .timeline-card-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .timeline-card-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .timeline-link {
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .timeline-link:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--item-color);
    color: var(--item-color);
  }

  .future-dot {
    background-color: rgba(15, 23, 42, 0.8);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.05);
    opacity: 0.7;
  }

  .timeline-future-text {
    font-size: 1.05rem;
    font-weight: 600;
    font-style: italic;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    background: linear-gradient(135deg, var(--text-muted) 30%, rgba(255, 255, 255, 0.3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shineText 3s infinite alternate;
  }

  @keyframes shineText {
    from { opacity: 0.7; }
    to { opacity: 1; filter: drop-shadow(0 0 1px rgba(255,255,255,0.1)); }
  }
</style>
