---
import type { Lang } from '../data/types';

interface Props {
  lang: Lang;
  view: string;
  navHomeText: string;
  navReposText: string;
  navVideosText: string;
  getPath: (path: string) => string;
}

const { lang, view, navHomeText, navReposText, navVideosText, getPath } = Astro.props;
---

<nav class="nav-bar">
  <div class="nav-links">
    <a href={getPath('')} class={`nav-item ${view === 'home' ? 'active' : ''}`} aria-label="Home">
      <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
      <span class="nav-text">{navHomeText}</span>
    </a>
    <a href={getPath('repositories')} class={`nav-item ${view === 'repositories' ? 'active' : ''}`} aria-label="Repositories">
      <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
        <path d="M9 18c-4.51 2-5-2-7-2"></path>
      </svg>
      <span class="nav-text">{navReposText}</span>
    </a>
    <a href={getPath('videos')} class={`nav-item ${view === 'videos' ? 'active' : ''}`} aria-label="YouTube">
      <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25a29 29 0 0 0-.46-5.33z"></path>
        <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
      </svg>
      <span class="nav-text">{navVideosText}</span>
    </a>
  </div>
  
  <div class="lang-switcher">
    <a href={view === 'home' ? '/' : (view === 'repositories' ? '/repositories' : '/videos')} class={`lang-btn ${lang === 'es' ? 'active' : ''}`}>ES</a>
    <a href={view === 'home' ? '/en' : (view === 'repositories' ? '/en/repositories' : '/en/videos')} class={`lang-btn ${lang === 'en' ? 'active' : ''}`}>EN</a>
    <a href={view === 'home' ? '/ca' : (view === 'repositories' ? '/ca/repositories' : '/ca/videos')} class={`lang-btn ${lang === 'ca' ? 'active' : ''}`}>CA</a>
  </div>
</nav>

<style>
  .nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 1.2rem;
    background: rgba(11, 15, 30, 0.7);
    border: 1px solid var(--border-color);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 9999px;
    margin-bottom: 3.5rem;
    position: sticky;
    top: 1.25rem;
    z-index: 100;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    transition: border-color 0.3s ease;
  }

  .nav-bar:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .nav-links {
    display: flex;
    gap: 0.5rem;
  }

  .nav-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.5rem 1.1rem;
    border-radius: 9999px;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-icon {
    width: 15px;
    height: 15px;
    stroke-width: 2.5;
  }

  .nav-item:hover {
    color: var(--text-main);
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-item.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.1);
  }

  .lang-switcher {
    display: flex;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0.2rem;
    border-radius: 9999px;
  }

  .lang-btn {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    transition: all 0.2s ease;
  }

  .lang-btn:hover {
    color: var(--text-main);
  }

  .lang-btn.active {
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--text-main);
  }

  @media (max-width: 650px) {
    .nav-bar {
      flex-direction: column;
      gap: 1rem;
      border-radius: 20px;
      padding: 0.8rem 1rem;
    }
    .nav-links {
      width: 100%;
      justify-content: center;
    }
    .lang-switcher {
      width: 100%;
      justify-content: center;
    }
  }
</style>
