---
import type { Lang } from '../data/types';
import HomeIcon from '../content/home.svg';
import GithubIcon from '../content/github.svg';
import YoutubeIcon from '../content/youtube.svg';

interface Props {
  lang: Lang;
  view: string;
  navHomeText: string;
  navReposText: string;
  navVideosText: string;
  getPath: (path: string) => string;
}

const { lang, view, navHomeText, navReposText, navVideosText, getPath } = Astro.props;
---

<nav class="nav-bar">
  <div class="nav-links">
    <a href={getPath('')} class={`nav-item ${view === 'home' ? 'active' : ''}`} aria-label="Home">
      <HomeIcon class="nav-icon" />
      <span class="nav-text">{navHomeText}</span>
    </a>
    <a href={getPath('repositories')} class={`nav-item ${view === 'repositories' ? 'active' : ''}`} aria-label="Repositories">
      <GithubIcon class="nav-icon" stroke-width="2.5" />
      <span class="nav-text">{navReposText}</span>
    </a>
    <a href={getPath('videos')} class={`nav-item ${view === 'videos' ? 'active' : ''}`} aria-label="YouTube">
      <YoutubeIcon class="nav-icon" stroke-width="2.5" />
      <span class="nav-text">{navVideosText}</span>
    </a>
  </div>
  
  <div class="lang-switcher">
    <a href={view === 'home' ? '/' : (view === 'repositories' ? '/repositories' : '/videos')} class={`lang-btn ${lang === 'es' ? 'active' : ''}`}>ES</a>
    <a href={view === 'home' ? '/en' : (view === 'repositories' ? '/en/repositories' : '/en/videos')} class={`lang-btn ${lang === 'en' ? 'active' : ''}`}>EN</a>
    <a href={view === 'home' ? '/ca' : (view === 'repositories' ? '/ca/repositories' : '/ca/videos')} class={`lang-btn ${lang === 'ca' ? 'active' : ''}`}>CA</a>
  </div>
</nav>

<style>
  .nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 1.2rem;
    background: rgba(11, 15, 30, 0.7);
    border: 1px solid var(--border-color);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 9999px;
    margin-bottom: 3.5rem;
    position: sticky;
    top: 1.25rem;
    z-index: 100;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    transition: border-color 0.3s ease;
  }

  .nav-bar:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .nav-links {
    display: flex;
    gap: 0.5rem;
  }

  .nav-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.5rem 1.1rem;
    border-radius: 9999px;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-icon {
    width: 15px;
    height: 15px;
    stroke-width: 2.5;
  }

  .nav-item:hover {
    color: var(--text-main);
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-item.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.1);
  }

  .lang-switcher {
    display: flex;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0.2rem;
    border-radius: 9999px;
  }

  .lang-btn {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    transition: all 0.2s ease;
  }

  .lang-btn:hover {
    color: var(--text-main);
  }

  .lang-btn.active {
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--text-main);
  }

  @media (max-width: 650px) {
    .nav-bar {
      flex-direction: column;
      gap: 1rem;
      border-radius: 20px;
      padding: 0.8rem 1rem;
    }
    .nav-links {
      width: 100%;
      justify-content: center;
    }
    .lang-switcher {
      width: 100%;
      justify-content: center;
    }
  }
</style>
