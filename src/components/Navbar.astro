---
import type { Lang } from '../data/types';
import HomeIcon from '../content/home.svg';
import GithubIcon from '../content/github.svg';
import YoutubeIcon from '../content/youtube.svg';

interface Props {
  lang: Lang;
  view: string;
  navHomeText: string;
  navReposText: string;
  navVideosText: string;
  getPath: (path: string) => string;
}

const { lang, view, navHomeText, navReposText, navVideosText, getPath } = Astro.props;
---

<button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Open menu">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <line x1="3" y1="6" x2="21" y2="6"></line>
    <line x1="3" y1="12" x2="21" y2="12"></line>
    <line x1="3" y1="18" x2="21" y2="18"></line>
  </svg>
</button>

<div class="mobile-overlay" id="mobile-overlay"></div>

<nav class="mobile-sidebar" id="mobile-sidebar">
  <div class="mobile-nav-links">
    <a href={getPath('')} class={`mobile-nav-item ${view === 'home' ? 'active' : ''}`}>
      <HomeIcon class="mobile-nav-icon" />
      <span>{navHomeText}</span>
    </a>
    <a href={getPath('repositories')} class={`mobile-nav-item ${view === 'repositories' ? 'active' : ''}`}>
      <GithubIcon class="mobile-nav-icon" stroke-width="2.5" />
      <span>{navReposText}</span>
    </a>
    <a href={getPath('videos')} class={`mobile-nav-item ${view === 'videos' ? 'active' : ''}`}>
      <YoutubeIcon class="mobile-nav-icon" stroke-width="2.5" />
      <span>{navVideosText}</span>
    </a>
  </div>
  <div class="mobile-lang-switcher">
    <a href={view === 'home' ? '/' : (view === 'repositories' ? '/repositories' : '/videos')} class={`mobile-lang-btn ${lang === 'es' ? 'active' : ''}`}>ES</a>
    <a href={view === 'home' ? '/en' : (view === 'repositories' ? '/en/repositories' : '/en/videos')} class={`mobile-lang-btn ${lang === 'en' ? 'active' : ''}`}>EN</a>
    <a href={view === 'home' ? '/ca' : (view === 'repositories' ? '/ca/repositories' : '/ca/videos')} class={`mobile-lang-btn ${lang === 'ca' ? 'active' : ''}`}>CA</a>
  </div>
</nav>

<nav class="nav-bar">
  <div class="nav-links">
    <a href={getPath('')} class={`nav-item ${view === 'home' ? 'active' : ''}`} aria-label="Home">
      <HomeIcon class="nav-icon" />
      <span class="nav-text">{navHomeText}</span>
    </a>
    <a href={getPath('repositories')} class={`nav-item ${view === 'repositories' ? 'active' : ''}`} aria-label="Repositories">
      <GithubIcon class="nav-icon" stroke-width="2.5" />
      <span class="nav-text">{navReposText}</span>
    </a>
    <a href={getPath('videos')} class={`nav-item ${view === 'videos' ? 'active' : ''}`} aria-label="YouTube">
      <YoutubeIcon class="nav-icon" stroke-width="2.5" />
      <span class="nav-text">{navVideosText}</span>
    </a>
  </div>
  
  <div class="lang-switcher">
    <a href={view === 'home' ? '/' : (view === 'repositories' ? '/repositories' : '/videos')} class={`lang-btn ${lang === 'es' ? 'active' : ''}`}>ES</a>
    <a href={view === 'home' ? '/en' : (view === 'repositories' ? '/en/repositories' : '/en/videos')} class={`lang-btn ${lang === 'en' ? 'active' : ''}`}>EN</a>
    <a href={view === 'home' ? '/ca' : (view === 'repositories' ? '/ca/repositories' : '/ca/videos')} class={`lang-btn ${lang === 'ca' ? 'active' : ''}`}>CA</a>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const overlay = document.getElementById('mobile-overlay');
  const sidebar = document.getElementById('mobile-sidebar');

  function openMenu() {
    overlay?.classList.add('open');
    sidebar?.classList.add('open');
  }

  function closeMenu() {
    overlay?.classList.remove('open');
    sidebar?.classList.remove('open');
  }

  menuBtn?.addEventListener('click', () => {
    if (sidebar?.classList.contains('open')) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  overlay?.addEventListener('click', closeMenu);

  sidebar?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>

<style>
  /* ===== MOBILE MENU BUTTON ===== */
  .mobile-menu-btn {
    display: none;
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 200;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    border: 1px solid var(--border-color);
    background: rgba(11, 15, 30, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    color: var(--text-main);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .mobile-menu-btn:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(20, 25, 50, 0.9);
  }

  /* ===== OVERLAY ===== */
  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 150;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .mobile-overlay.open {
    opacity: 1;
  }

  /* ===== SIDEBAR ===== */
  .mobile-sidebar {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 280px;
    height: 100vh;
    height: 100dvh;
    background: rgba(11, 15, 30, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-right: 1px solid var(--border-color);
    z-index: 160;
    padding: 5rem 1.5rem 2rem;
    transform: translateX(-100%);
    transition: transform 0.3s ease-out;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow-y: auto;
  }

  .mobile-sidebar.open {
    transform: translateX(0);
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 1rem;
    font-weight: 700;
    padding: 0.85rem 1rem;
    border-radius: 12px;
    transition: all 0.2s ease;
  }

  .mobile-nav-item:hover {
    color: var(--text-main);
    background: rgba(255, 255, 255, 0.04);
  }

  .mobile-nav-item.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.1);
  }

  .mobile-nav-icon {
    width: 18px;
    height: 18px;
    stroke-width: 2.5;
    flex-shrink: 0;
  }

  .mobile-lang-switcher {
    display: flex;
    gap: 0.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border-color);
  }

  .mobile-lang-btn {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: all 0.2s ease;
  }

  .mobile-lang-btn:hover {
    color: var(--text-main);
  }

  .mobile-lang-btn.active {
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--text-main);
  }

  /* ===== DESKTOP NAVBAR (original) ===== */
  .nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 1.2rem;
    background: rgba(11, 15, 30, 0.7);
    border: 1px solid var(--border-color);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 9999px;
    margin-bottom: 3.5rem;
    position: sticky;
    top: 1.25rem;
    z-index: 100;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    transition: border-color 0.3s ease;
  }

  .nav-bar:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .nav-links {
    display: flex;
    gap: 0.5rem;
  }

  .nav-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.5rem 1.1rem;
    border-radius: 9999px;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-icon {
    width: 15px;
    height: 15px;
    stroke-width: 2.5;
  }

  .nav-item:hover {
    color: var(--text-main);
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-item.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.1);
  }

  .lang-switcher {
    display: flex;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0.2rem;
    border-radius: 9999px;
  }

  .lang-btn {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    transition: all 0.2s ease;
  }

  .lang-btn:hover {
    color: var(--text-main);
  }

  .lang-btn.active {
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--text-main);
  }

  /* ===== MOBILE BREAKPOINT ===== */
  @media (max-width: 650px) {
    .nav-bar {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }

    .mobile-overlay {
      display: block;
    }

    .mobile-sidebar {
      display: flex;
    }
  }
</style>
