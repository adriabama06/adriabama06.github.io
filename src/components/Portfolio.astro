---
import '../styles/global.css';
import type { Lang } from '../data/types';
import { translations } from '../data/translations';
import { repos, videos } from '../data/content';
import { getPath as getPathHelper } from '../utils/paths';
import Navbar from './Navbar.astro';
import HomeView from './HomeView.astro';
import ReposView from './ReposView.astro';
import VideosView from './VideosView.astro';
import Footer from './Footer.astro';

interface Props {
  lang: Lang;
  view?: 'home' | 'repositories' | 'videos';
}

const { lang, view = 'home' } = Astro.props;
const t = translations[lang];
const getPath = (path: string) => getPathHelper(lang, path);
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> -->
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>{t.metaTitle}</title>
</head>
<body>
  <div class="container">
    <Navbar
      lang={lang}
      view={view}
      navHomeText={t.navHome}
      navReposText={t.navRepos}
      navVideosText={t.navVideos}
      getPath={getPath}
    />

    {view === 'home' && (
      <HomeView lang={lang} t={t} repos={repos} videos={videos} getPath={getPath} />
    )}

    {view === 'repositories' && (
      <ReposView lang={lang} t={t} repos={repos} getPath={getPath} />
    )}

    {view === 'videos' && (
      <VideosView lang={lang} t={t} videos={videos} getPath={getPath} />
    )}

    <Footer
      socialsTitleText={t.socialsTitle}
      discordTooltipText={t.discordTooltip}
      linkedinFutureText={t.linkedinFuture}
      emailTooltipText={t.emailTooltip}
      emailSubjectText={t.emailSubject}
    />
  </div>
</body>
</html>
