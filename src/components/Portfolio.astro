  <!-- Client-side script for copy-to-clipboard -->
  <script>
    const copyBtn = document.getElementById('discord-copy-btn');
    const label = document.getElementById('discord-label');
    
    if (copyBtn && label) {
      const originalText = label.textContent || 'Discord';
      const tooltipText = copyBtn.getAttribute('data-tooltip') || 'adriabama06';
      const copiedText = copyBtn.getAttribute('data-copied') || 'Copied!';
      
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText('adriabama06');
          label.textContent = copiedText;
          copyBtn.classList.add('copied');
          
          setTimeout(() => {
            label.textContent = originalText;
            copyBtn.classList.remove('copied');
          }, 2500);
        } catch (err) {
          console.error('Could not copy text: ', err);
        }
      });
    }
  </script>
